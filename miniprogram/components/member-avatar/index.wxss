/* components/member-avatar/index.wxss */

.avatar-wrap {
  border-radius: var(--radius-full);
  overflow: hidden;
  flex-shrink: 0;
}

.avatar-sm {
  width: 48rpx;
  height: 48rpx;
}

.avatar-md {
  width: 72rpx;
  height: 72rpx;
}

.avatar-lg {
  width: 96rpx;
  height: 96rpx;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-default {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-initial {
  color: #FFFFFF;
  font-weight: 600;
  font-size: 24rpx;
}

.avatar-sm .avatar-initial {
  font-size: 18rpx;
}

.avatar-lg .avatar-initial {
  font-size: 32rpx;
}
