/* components/todo-card/index.wxss — 简约优化 */

.todo-card {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: 18rpx var(--spacing-lg);
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  margin-bottom: var(--spacing-sm);
  box-shadow: var(--shadow-sm);
  transition: all 0.15s ease;
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.todo-card:active {
  transform: scale(0.985);
  background: var(--bg-card-hover);
}

.todo-completed {
  opacity: 0.65;
}

/* ===== 勾选框 ===== */
.check-box {
  flex-shrink: 0;
  padding: 2rpx;
}

.check-circle {
  width: 44rpx;
  height: 44rpx;
  border-radius: var(--radius-full);
  border: 2.5rpx solid var(--border-color);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
}

.check-circle:active {
  transform: scale(0.9);
}

.check-circle.checked {
  background: var(--primary);
  border-color: var(--primary);
}

/* ===== 内容区 ===== */
.todo-content {
  overflow: hidden;
  min-width: 0;
}

.todo-title-row {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
}

.todo-title {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.title-done {
  text-decoration: line-through;
  color: var(--text-tertiary);
  font-weight: 400;
}

.title-overdue {
  color: var(--danger);
}

/* ===== 元数据行 ===== */
.todo-meta {
  margin-top: 2rpx;
}

.meta-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: var(--spacing-xs);
}

.meta-text {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.category-text {
  font-weight: 500;
}

.meta-dot {
  font-size: 22rpx;
  color: var(--text-tertiary);
}

.text-danger {
  color: var(--danger);
  font-weight: 500;
}
