<!--components/todo-card/index.wxml-->
<view class="todo-card {{isCompleted ? 'todo-completed' : ''}}" bindtap="onCardTap">
  <!-- 优先级左侧指示 -->
  <view class="priority-bar priority-{{priorityInfo.key || 'none'}}"></view>

  <!-- 勾选框 -->
  <view class="check-box" data-id="{{item._id}}" bindtap="onToggleComplete">
    <view class="check-circle {{isCompleted ? 'checked' : ''}}">
      <van-icon wx:if="{{isCompleted}}" name="success" size="11px" color="#FFF" />
    </view>
  </view>

  <!-- 内容区 -->
  <view class="todo-content flex-1">
    <view class="todo-title-row">
      <text class="todo-title {{isCompleted ? 'title-done' : ''}} {{isOverdue ? 'title-overdue' : ''}}">{{item.title}}</text>
      <van-icon wx:if="{{item.priority === 3}}" name="warning-o" size="14px" color="#FF3B30" />
    </view>
    <view class="todo-meta" wx:if="{{item.dueDate || item.categoryId || item.assigneeId}}">
      <view class="meta-row">
        <!-- 分类色点 -->
        <view wx:if="{{item.categoryColor}}" class="category-dot mr-xs" style="background: {{item.categoryColor}}"></view>
        <text wx:if="{{item.categoryName}}" class="meta-text category-text">{{item.categoryName}}</text>
        <text wx:if="{{item.categoryName && timeDesc}}" class="meta-dot">·</text>
        <!-- 时间 -->
        <text wx:if="{{timeDesc}}" class="meta-text {{isOverdue ? 'text-danger' : ''}}">{{timeDesc}}</text>
      </view>
    </view>
  </view>

  <!-- 分配人头像 -->
  <member-avatar
    wx:if="{{item.assigneeInfo}}"
    member="{{item.assigneeInfo}}"
    size="sm"
  />
</view>
