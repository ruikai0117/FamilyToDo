/* components/empty-state/index.wxss */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) 0;
  gap: var(--spacing-sm);
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-secondary);
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  text-align: center;
  max-width: 400rpx;
}
