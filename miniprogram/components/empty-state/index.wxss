/* components/empty-state/index.wxss — 简约优化 */

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl) var(--spacing-md);
  gap: var(--spacing-sm);
}

.empty-title {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-secondary);
  letter-spacing: -0.3rpx;
}

.empty-desc {
  font-size: var(--font-sm);
  color: var(--text-tertiary);
  text-align: center;
  max-width: 380rpx;
  line-height: 1.6;
}
