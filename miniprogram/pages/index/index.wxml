<!--pages/index/index.wxml-->
<view class="page-todo">
  <!-- 顶部导航 -->
  <view class="nav-header">
    <view class="nav-family" bindtap="onSwitchFamily">
      <text class="family-name">{{familyName || '我的家庭'}}</text>
      <van-icon name="arrow-down" size="12px" color="#8E8E93" />
    </view>
  </view>

  <!-- 筛选栏 -->
  <scroll-view class="filter-bar" scroll-x enhanced show-scrollbar="{{false}}">
    <view class="filter-list">
      <view
        wx:for="{{filters}}"
        wx:key="key"
        class="filter-item {{currentFilter === item.key ? 'filter-active' : ''}}"
        data-key="{{item.key}}"
        bindtap="onFilterTap"
      >
        <text>{{item.label}}</text>
      </view>
    </view>
  </scroll-view>

  <!-- 待办列表 -->
  <view class="todo-list">
    <block wx:if="{{!isEmpty}}">
      <van-swipe-cell
        wx:for="{{todoList}}"
        wx:key="_id"
        right-width="{{72}}"
        async-close
      >
        <todo-card
          item="{{item}}"
          bind:toggle="onToggleComplete"
          bind:tap="onTodoTap"
        />
        <view slot="right" class="swipe-delete" data-id="{{item._id}}" bindtap="onDeleteTodo">
          删除
        </view>
      </van-swipe-cell>
    </block>

    <!-- 空状态 -->
    <empty-state wx:if="{{isEmpty && !loading}}" type="todo" />

    <!-- 加载状态 -->
    <view wx:if="{{loading}}" class="loading-wrap">
      <van-loading size="18px" color="#8E8E93" />
    </view>

    <!-- 没有更多 -->
    <view wx:if="{{!hasMore && todoList.length > 0 && !loading}}" class="no-more">
      <text>没有更多了</text>
    </view>
  </view>

  <!-- 浮动添加按钮 -->
  <view class="fab" bindtap="onFabTap">
    <van-icon name="plus" size="22px" color="#FFFFFF" />
  </view>
</view>
