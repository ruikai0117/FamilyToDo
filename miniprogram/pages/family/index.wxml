<!--pages/family/index.wxml-->
<view class="page-family">
  <!-- 家庭信息卡片 -->
  <view class="family-card" wx:if="{{currentFamily}}">
    <view class="family-header flex-between">
      <view class="family-info">
        <text class="family-name">{{currentFamily.name}}</text>
        <text class="family-date">创建于 {{currentFamily.createTime}}</text>
      </view>
      <view class="invite-code-wrap" bindtap="onCopyInviteCode">
        <text class="invite-code">{{currentFamily.inviteCode}}</text>
        <van-icon name="edit" size="11px" color="#0071E3" custom-class="copy-icon" />
      </view>
    </view>

    <!-- 成员列表 -->
    <view class="member-section">
      <view class="section-header flex-between">
        <text class="section-title">家庭成员 · {{members.length}}</text>
        <text class="section-action text-accent" bindtap="onManageMembers">管理</text>
      </view>
      <view class="member-row">
        <view wx:for="{{members}}" wx:key="_id" class="member-brief">
          <member-avatar member="{{item}}" />
          <text class="member-name">{{item.nickName}}</text>
          <van-tag
            wx:if="{{item.role === 'admin'}}"
            type="primary"
            size="medium"
            round
            custom-class="admin-tag"
          >管理员</van-tag>
        </view>
      </view>
    </view>
  </view>

  <!-- 无家庭提示 -->
  <view class="no-family" wx:if="{{!currentFamily}}">
    <van-icon name="home-o" size="48px" color="#C7C7CC" />
    <text class="no-family-text">还没有加入家庭</text>
    <text class="no-family-hint">创建或加入一个家庭，开始协作管理待办</text>
  </view>

  <!-- 快捷操作 -->
  <view class="action-card">
    <van-cell-group border="{{false}}" custom-class="action-group">
      <van-cell
        title="创建家庭"
        icon="add-o"
        is-link
        bindtap="onCreateFamily"
        custom-class="action-cell"
      />
      <van-cell
        title="加入家庭"
        icon="friends-o"
        is-link
        bindtap="onJoinFamily"
        custom-class="action-cell"
      />
    </van-cell-group>
  </view>

  <!-- 多家庭切换 -->
  <view class="switch-section" wx:if="{{familyList.length > 1}}">
    <text class="section-title">切换家庭</text>
    <view class="family-list">
      <view
        wx:for="{{familyList}}"
        wx:key="_id"
        class="family-list-item {{item._id === currentFamily._id ? 'family-active' : ''}}"
        data-id="{{item._id}}"
        bindtap="onSwitchFamily"
      >
        <view class="family-list-icon">
          <van-icon name="home-o" size="18px" color="#0071E3" />
        </view>
        <view class="family-list-info flex-1">
          <text class="family-list-name">{{item.name}}</text>
          <text class="family-list-members">{{item.memberCount}} 位成员</text>
        </view>
        <van-icon wx:if="{{item._id === currentFamily._id}}" name="success" color="#0071E3" size="16px" />
      </view>
    </view>
  </view>

  <!-- 退出家庭 -->
  <view class="leave-section" wx:if="{{currentFamily}}">
    <van-button
      plain
      type="danger"
      block
      round
      bindtap="onLeaveFamily"
      custom-class="leave-btn"
    >退出家庭</van-button>
  </view>

  <!-- 创建家庭弹窗 -->
  <van-popup
    show="{{showCreateFamily}}"
    position="bottom"
    round
    bind:close="onCreateClose"
  >
    <view class="popup-content">
      <view class="popup-header flex-between">
        <text class="popup-title">创建家庭</text>
        <van-icon name="cross" size="20px" color="#8E8E93" bindtap="onCreateClose" />
      </view>
      <van-field
        value="{{newFamilyName}}"
        label="家庭名称"
        placeholder="例如：温馨小家"
        border="{{true}}"
        maxlength="20"
        show-word-limit
        bind:change="onNewFamilyNameInput"
      />
      <view class="popup-footer safe-bottom">
        <van-button type="primary" block round bindtap="onCreateConfirm">创建</van-button>
      </view>
    </view>
  </van-popup>

  <!-- 加入家庭弹窗 -->
  <van-popup
    show="{{showJoinFamily}}"
    position="bottom"
    round
    bind:close="onJoinClose"
  >
    <view class="popup-content">
      <view class="popup-header flex-between">
        <text class="popup-title">加入家庭</text>
        <van-icon name="cross" size="20px" color="#8E8E93" bindtap="onJoinClose" />
      </view>
      <van-field
        value="{{inviteCode}}"
        label="邀请码"
        placeholder="输入 6 位邀请码"
        border="{{true}}"
        maxlength="6"
        bind:change="onInviteCodeInput"
      />
      <view class="popup-footer safe-bottom">
        <van-button type="primary" block round bindtap="onJoinConfirm">加入</van-button>
      </view>
    </view>
  </van-popup>
</view>
