/* pages/family/index.wxss — 简约优化 */

.page-family {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding: var(--spacing-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* ===== 家庭卡片 ===== */
.family-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1rpx solid var(--divider-color);
}

.family-header {
  margin-bottom: var(--spacing-md);
}

.family-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.family-name {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
}

.family-date {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

.invite-code-wrap {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 10rpx 18rpx;
  background: var(--primary-bg);
  border-radius: var(--radius-full);
}

.invite-code {
  font-size: var(--font-md);
  font-weight: 700;
  color: var(--primary);
  letter-spacing: 3rpx;
  font-variant-numeric: tabular-nums;
}

/* ===== 成员区域 ===== */
.member-section {
  border-top: 1rpx solid var(--divider-color);
  padding-top: var(--spacing-md);
}

.section-header {
  margin-bottom: var(--spacing-md);
}

.section-title {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
}

.section-action {
  font-size: var(--font-sm);
  font-weight: 500;
}

.member-row {
  display: flex;
  flex-wrap: wrap;
  gap: var(--spacing-md);
}

.member-brief {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
  min-width: 120rpx;
}

.member-name {
  font-size: 22rpx;
  color: var(--text-primary);
  text-align: center;
  max-width: 120rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.admin-tag {
  font-size: 18rpx !important;
  padding: 2rpx 12rpx !important;
  transform: scale(0.85);
}

/* ===== 无家庭提示 ===== */
.no-family {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: var(--spacing-xl);
  gap: var(--spacing-sm);
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
}

.no-family-text {
  font-size: var(--font-lg);
  font-weight: 500;
  color: var(--text-primary);
}

.no-family-hint {
  font-size: var(--font-sm);
  color: var(--text-secondary);
  text-align: center;
  line-height: 1.6;
}

/* ===== 操作卡片 ===== */
.action-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
}

.action-group {
  overflow: hidden !important;
}

/* ===== 切换家庭 ===== */
.switch-section {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
}

.family-list {
  margin-top: var(--spacing-sm);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.family-list-item {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-md);
  border-radius: var(--radius-md);
  transition: background 0.15s ease;
}

.family-list-item:active {
  background: var(--bg-secondary);
}

.family-list-item.family-active {
  background: var(--primary-bg);
}

.family-list-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: var(--radius-md);
  background: var(--primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.family-list-info {
  display: flex;
  flex-direction: column;
  gap: 2rpx;
}

.family-list-name {
  font-size: var(--font-md);
  font-weight: 500;
  color: var(--text-primary);
}

.family-list-members {
  font-size: var(--font-xs);
  color: var(--text-secondary);
}

/* ===== 退出家庭 ===== */
.leave-section {
  margin-top: var(--spacing-xl);
  padding: 0 var(--spacing-md);
}

.leave-btn .van-button__text {
  font-weight: 500;
}

/* ===== 弹窗 ===== */
.popup-content {
  padding: var(--spacing-lg);
}

.popup-header {
  margin-bottom: var(--spacing-lg);
}

.popup-title {
  font-size: 34rpx;
  font-weight: 600;
  letter-spacing: -0.3rpx;
}

.popup-footer {
  padding-top: var(--spacing-md);
}
