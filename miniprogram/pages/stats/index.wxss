/* pages/stats/index.wxss — 简约优化 */

.page-stats {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding: var(--spacing-md);
  padding-bottom: calc(env(safe-area-inset-bottom) + 32rpx);
}

/* ===== 概览卡片 ===== */
.overview-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.overview-header {
  margin-bottom: var(--spacing-lg);
}

.overview-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
}

.overview-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  margin-bottom: var(--spacing-lg);
}

.overview-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 6rpx;
}

.overview-value {
  font-size: var(--font-xxl);
  font-weight: 700;
  letter-spacing: -0.5rpx;
  font-variant-numeric: tabular-nums;
}

.overview-label {
  font-size: 22rpx;
  color: var(--text-secondary);
}

.overview-divider {
  width: 1rpx;
  height: 56rpx;
  background: var(--divider-color);
}

.overview-progress {
  margin-top: var(--spacing-sm);
}

/* ===== 区块卡片 ===== */
.section-card {
  background: var(--bg-card);
  border-radius: var(--radius-xl);
  padding: var(--spacing-lg);
  box-shadow: var(--shadow-sm);
  margin-bottom: var(--spacing-md);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
}

.section-title {
  font-size: var(--font-lg);
  font-weight: 600;
  color: var(--text-primary);
  letter-spacing: -0.3rpx;
  margin-bottom: var(--spacing-md);
  display: block;
}

/* ===== 成员排行 ===== */
.rank-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) 0;
}

.rank-item + .rank-item {
  border-top: 1rpx solid var(--divider-color);
}

.rank-left {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex: 1;
  min-width: 0;
}

.rank-index {
  width: 36rpx;
  height: 36rpx;
  border-radius: var(--radius-full);
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 20rpx;
  font-weight: 600;
  color: var(--text-secondary);
  flex-shrink: 0;
}

.rank-index-1 {
  background: #F5C518;
  color: #FFF;
}

.rank-index-2 {
  background: #C0C0C0;
  color: #FFF;
}

.rank-index-3 {
  background: #CD7F32;
  color: #FFF;
}

.rank-name {
  font-size: var(--font-md);
  color: var(--text-primary);
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.rank-right {
  display: flex;
  align-items: center;
  gap: 4rpx;
  flex-shrink: 0;
  min-width: 160rpx;
  justify-content: flex-end;
}

.rank-count {
  font-size: var(--font-md);
  font-weight: 600;
  color: var(--text-primary);
  font-variant-numeric: tabular-nums;
}

.rank-unit {
  font-size: var(--font-xs);
  color: var(--text-secondary);
  margin-right: var(--spacing-sm);
}

.rank-progress {
  flex: 1;
  min-width: 60rpx;
  max-width: 120rpx;
}

/* ===== 图表空状态 ===== */
.chart-empty {
  padding: var(--spacing-md) 0;
}

/* ===== 加载状态 ===== */
.loading-wrap {
  display: flex;
  justify-content: center;
  padding: var(--spacing-xl) 0;
}
